{
  "name": "example-news-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/server.ts",
    "build:app": "bun run src/scripts/build-app.ts",
    "check-types": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/scripts/seed.ts"
  },
  "dependencies": {
    "@graphql-suite/client": "workspace:@drizzle-graphql-suite/client@*",
    "@graphql-suite/query": "workspace:@drizzle-graphql-suite/query@*",
    "@graphql-suite/schema": "workspace:@drizzle-graphql-suite/schema@*",
    "drizzle-orm": "0.45.1",
    "graphql": "16.13.1",
    "graphql-yoga": "5.18.1"
  },
  "devDependencies": {
    "@tanstack/react-query": "5.90.21",
    "@types/bun": "1.3.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.9",
    "linkedom": "0.18.12",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "5.9.3"
  }
}
